  "technical_debt": [
    {
      "id": "debt-1",
      "title": "Service Worker Cache Management",
      "severity": "high",
      "description": "Service worker aggressively caches manifest.json and icons, making updates invisible to users without manual cache clear",
      "impact": "PWA updates don't appear; icon changes not reflected",
      "proposed_solution": "Implement versioned cache names with automatic cleanup of old caches on service worker update"
    },
    {
      "id": "debt-2",
      "title": "Firebase Config Security",
      "severity": "medium",
      "description": "Firebase config exposed in client-side code",
      "impact": "API keys visible in source code",
      "proposed_solution": "Move sensitive operations to Firebase Functions, implement security rules"
    },
    {
      "id": "debt-3",
      "title": "A-Frame Performance",
      "severity": "low",
      "description": "AR tracking can be slow on older devices",
      "impact": "Poor UX on budget phones",
      "proposed_solution": "Optimize 3D models, reduce polygon count, implement quality settings"
    }
  ],
  
